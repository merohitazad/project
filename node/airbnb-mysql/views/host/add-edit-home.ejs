<%- include("../partials/head") %>

  <body class=" bg-gray-100 min-h-screen">
    <%- include("../partials/header") %>
      <main class="flex justify-center items-center w-full">
        <div class="w-1/2 bg-white shadow-2xl rounded-2xl p-10 text-center bg-gradient-to-br from-red-100
          via-white to-pink-100">

          <!-- Header -->
          <div class="mb-6 text-center">
            <h1 class="text-3xl font-bold text-red-600 mb-2">
              <%= editing ? "Edit" : "Register" %> Your Home
            </h1>
            <p class="text-gray-500 text-sm">
              List your property and start earning
            </p>
          </div>

          <!-- Form -->

          <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST" class="space-y-5">

            <!-- Input Field -->
            <div class="flex flex-wrap w-full justify-center items-center">
              <div class="px-4 py-2">
                <input type="hidden" name="id" value="<%= editing ? home._id :''%>" />
                <label class="block text-gray-700 font-medium mb-2">
                  House Name
                </label>
                <input type="text" name="houseName" value="<%= editing ? home.houseName :''%>" placeholder="Enter your house name"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
              <div class="px-4 py-2">
                <label class="block text-gray-700 font-medium mb-2">
                  Price Per Night
                </label>
                <input type="text" name="pricePerNight" value="<%= editing ? home.pricePerNight :''%>" placeholder="Enter stay price per night"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
              <div class="px-4 py-2">
                <label class="block text-gray-700 font-medium mb-2">
                  Location
                </label>
                <input type="text" name="location" value="<%= editing ? home.location :''%>" placeholder="Enter your house location"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
              <div class="px-4 py-2">
                <label class="block text-gray-700 font-medium mb-2">
                  Rating
                </label>
                <input type="text" name="rating" value="<%= editing ? home.rating :''%>" placeholder="Enter your house rating"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
              <div class="px-4 py-2">
                <label class="block text-gray-700 font-medium mb-2">
                  Image Link
                </label>
                <input type="text" name="imageLink" value="<%= editing ? home.imageLink :''%>" placeholder="Enter your house image"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
              <div class="px-4 py-2">
                <label class="block text-gray-700 font-medium mb-2">
                  Description
                </label>
                <input type="text" name="description" value="<%= editing ? home.description :''%>" placeholder="Describe your place"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent transition" />
              </div>
            </div>

            <!-- Submit Button -->
            <button type="submit"
              class="w-full bg-red-500 text-white py-3 rounded-lg font-semibold text-lg shadow-md hover:bg-red-600 hover:scale-[1.02] transition duration-300">
              <%= editing ? "Update Home":"Add Home"%>
            </button>

          </form>
        </div>
      </main>

  </body>

  </html>