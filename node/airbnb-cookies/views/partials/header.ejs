<header class="bg-red-500 text-white shadow-md">
  <!-- 🔴 Navbar -->
  <nav>
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <!-- Logo -->
      <a href="/" class="text-xl font-bold flex justify-center items-center"
        >Airbnb</a
      >

      <!-- Nav Links -->
      <div class="space-x-6 font-medium px-6">
        <a
          href="/home"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Homes</a
        >
        <% if (isLoggedIn) { %>
          <% if(user && user.userType === "guest") { %>
        <a
          href="/bookings"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'bookings' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Bookings</a
        >
        <a
          href="/favourites"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'favourites' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Favourites</a
        >
          <% } else { %>
        <a
          href="/host/host-home-list"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'hostHomes' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Host Homes</a
        >
        <a
          href="/host/add-home"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'addHome' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Add Home</a
        >
        <% } %>  
        <% } %> 
         <% if (!isLoggedIn) { %>
        <a
          href="/login"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'login' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >Login</a> 
          <a
          href="/signup"
          class="px-6 py-1 rounded-lg <%= typeof currentPage !== 'undefined' && currentPage === 'signup' ? 'bg-red-400' : 'hover:bg-red-400' %>"
          >SignUp</a> 
          <% } else { %>
          <form action="/logout" method="POST" class="inline-block">
            <button type="submit" class="px-6 py-1 rounded-lg hover:bg-red-400">Logout</button>
          </form>
          <% } %>
      </div>
    </div>
  </nav>
</header>
