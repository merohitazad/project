<%- include("../partials/head") %>

<body class="bg-gray-50 min-h-screen flex flex-col justify-between text-gray-800">
  <%- include("../partials/header") %>
  
  <main class="flex-grow flex justify-center items-center px-4">
    <div class="w-full max-w-xl bg-white shadow-xl rounded-2xl border border-gray-100 p-8 md:p-10">

      <!-- Header -->
      <div class="mb-8 text-center">
        <h1 class="text-3xl font-extrabold text-red-500 tracking-tight mb-2">
          Create your airbnb account
        </h1>
        <p class="text-gray-900 text-lg">Join the Airbnb community today</p>
      </div>

      <!-- Form -->
      <form action="/signup" method="POST" class="space-y-6">

        <!-- Grid Container for Name Fields -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <%- include("../partials/errors") %>
          <!-- First Name -->
          <div>
            <label class="block text-gray-700 text-sm font-semibold mb-2">
              First Name
            </label>
            <input type="text" name="firstName" value="<%= typeof oldInput !== 'undefined' ? oldInput.firstName : '' %>" placeholder="John"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition" 
              required />
            <p class="text-red-500 text-sm mt-1 error-message"></p>
          </div>
          
          <!-- Last Name (Fixed type & placeholder) -->
          <div>
            <label class="block text-gray-700 text-sm font-semibold mb-2">
              Last Name
            </label>
            <input type="text" name="lastName" value="<%= typeof oldInput !== 'undefined' ? oldInput.lastName : '' %>" placeholder="Doe"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition" 
               />
            <p class="text-red-500 text-sm mt-1 error-message"></p>
          </div>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-gray-700 text-sm font-semibold mb-2">
            Email Address
          </label>
          <input type="email" name="email" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" placeholder="you@example.com"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition" 
            required />
          <p class="text-red-500 text-sm mt-1 error-message"></p>
          </div>

        <!-- Password -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-gray-700 text-sm font-semibold mb-2">
              Password
            </label>
            <input type="password" name="password" placeholder="Create a password"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition" 
              required />
            <p class="text-red-500 text-sm mt-1 error-message"></p>
          </div>

          <!-- Confirm Password -->
          <div>
            <label class="block text-gray-700 text-sm font-semibold mb-2">
              Confirm Password
            </label>
            <input type="password" name="confirmPassword" placeholder="Repeat your password"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition" 
              required />
            <p class="text-red-500 text-sm mt-1 error-message"></p>
          </div>
        </div>

        <!-- User Type Selection -->
        <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
          <span class="block text-gray-700 text-sm font-semibold mb-3">I want to join as a:</span>
          <div class="flex gap-6">
            <label class="flex items-center gap-2 text-gray-700 font-medium cursor-pointer">
              <input type="radio" name="userType" value="guest" <%= typeof oldInput !== 'undefined' && oldInput.userType === 'guest' ? 'checked' : '' %> class="w-4 h-4 text-red-500 focus:ring-red-500 border-gray-300" required>
              <span>Guest (Traveler)</span>
            </label>
            <label class="flex items-center gap-2 text-gray-700 font-medium cursor-pointer">
              <input type="radio" name="userType" value="host" <%= typeof oldInput !== 'undefined' && oldInput.userType === 'host' ? 'checked' : '' %> class="w-4 h-4 text-red-500 focus:ring-red-500 border-gray-300" required>
              <span>Host (Rent out space)</span>
            </label>
          </div>
        </div>

        <!-- Terms and Conditions -->
        <div class="flex items-start gap-3">
          <input type="checkbox" id="terms" name="terms" <%= typeof oldInput !== 'undefined' && oldInput.terms === 'on' ? 'checked' : '' %> class="mt-1 w-4 h-4 text-red-500 focus:ring-red-500 border-gray-300 rounded" required>
          <label for="terms" class="text-sm text-gray-600 leading-tight cursor-pointer">
            I agree to the <a href="#" class="text-red-500 hover:underline">Terms of Service</a> and <a href="#" class="text-red-500 hover:underline">Privacy Policy</a>.
          </label>
        </div>

        <!-- Submit Button -->
        <button type="submit"
          class="w-full bg-red-500 text-white py-3 rounded-lg font-bold text-lg shadow-md hover:bg-red-600 transition duration-200 active:scale-[0.99]">
          Sign Up
        </button>

      </form>
      <!-- Already Have an Account divider & link -->
      <div class="pt-6 border-t border-gray-100 text-center">
        <p class="text-gray-600 text-sm">
          Already have an account? 
          <a href="/login" class="text-red-500 font-semibold hover:underline ml-1 transition duration-150">
            Log in
          </a>
        </p>
      </div>
    </div>
  </main>

  // Script for client-side validation
  <script>
  const form = document.querySelector("form");

  form.addEventListener("submit", function (e) {
    let isValid = true;

    // Clear previous errors
    document.querySelectorAll(".error-message").forEach((el) => {
      el.textContent = "";
    });

    document.querySelectorAll("input").forEach((input) => {
      input.classList.remove("border-red-500");
    });

    // Input fields
    const firstName = document.querySelector(
      'input[name="firstName"]'
    );

    const lastName = document.querySelector(
      'input[name="lastName"]'
    );

    const email = document.querySelector(
      'input[name="email"]'
    );

    const password = document.querySelector(
      'input[name="password"]'
    );

    const confirmPassword = document.querySelector(
      'input[name="confirmPassword"]'
    );

    // Helper function
    function showError(input, message) {
      isValid = false;

      input.classList.add("border-red-500");

      input.parentElement.querySelector(
        ".error-message"
      ).textContent = message;
    }

    // First Name
    if (
      firstName.value.trim().length < 2 ||
      firstName.value.trim().length > 100
    ) {
      showError(
        firstName,
        "First name must be between 2 and 100 characters"
      );
    } else if (
      !/^[a-zA-Z]+$/.test(firstName.value.trim())
    ) {
      showError(
        firstName,
        "First name must contain only letters"
      );
    }

    // Last Name (optional)
    if (
      lastName.value.trim() &&
      !/^[a-zA-Z]+$/.test(lastName.value.trim())
    ) {
      showError(
        lastName,
        "Last name must contain only letters"
      );
    }

    // Email
    const emailRegex =
      /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailRegex.test(email.value.trim())) {
      showError(email, "Please enter a valid email");
    }

    // Password
    if (password.value.length < 8) {
      showError(
        password,
        "Password must be at least 8 characters long"
      );
    } else if (!/[A-Z]/.test(password.value)) {
      showError(
        password,
        "Password must contain at least one uppercase letter"
      );
    } else if (!/[a-z]/.test(password.value)) {
      showError(
        password,
        "Password must contain at least one lowercase letter"
      );
    } else if (!/[0-9]/.test(password.value)) {
      showError(
        password,
        "Password must contain at least one number"
      );
    } else if (!/[@$!%*?&]/.test(password.value)) {
      showError(
        password,
        "Password must contain at least one special character"
      );
    }

    // Confirm Password
    if (
      confirmPassword.value !== password.value
    ) {
      showError(
        confirmPassword,
        "Passwords do not match"
      );
    }

    // Prevent form submission
    if (!isValid) {
      e.preventDefault();
    }
  });
</script>
</body>
</html>